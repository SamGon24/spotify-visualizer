@startuml Spotify-Visualizer-FileStructure

!define ROOT_COLOR #E3F2FD
!define BACKEND_COLOR #C8E6C9
!define FRONTEND_COLOR #FFE0B2
!define CONFIG_COLOR #F3E5F5

skinparam backgroundColor #FAFAFA

title Spotify Visualizer - Complete File Structure

package "📁 spotify-visualizer/" <<ROOT_COLOR>> {

    package "🔧 Configuration Files" <<CONFIG_COLOR>> {
        file ".env\n(Environment variables)" as env
        file ".gitignore\n(Git ignore rules)" as gitignore
        file "requirements.txt\n(Python dependencies)" as requirements
        file "ARCHITECTURE.md\n(Architecture docs)" as arch_md
        file "SETUP_AND_RUN.md\n(Setup instructions)" as setup_md
        file "README.md\n(Project readme)" as readme
    }

    package "🐍 Backend - app/" <<BACKEND_COLOR>> {
        
        package "Main Module" {
            file "__init__.py\n(Flask app init)" as app_init
            file "__main__.py\n(Entry point)" as app_main
            file "routes.py\n(API routes)" as app_routes
            note right of app_routes
                Routes:
                • /login
                • /callback
                • /user
                • /recent
                • /top/tracks/<period>
                • /top/artists/<period>
            end note
        }
        
        package "services/" {
            file "spotify_client.py\n(Spotify API wrapper)" as spotify_client
            file "spotify_data.py\n(Data processing)" as spotify_data
            note right of spotify_data
                Functions:
                • get_recently_played()
                • get_top_tracks()
                • get_top_artists()
                • get_top_tracks_last_7_days()
                • get_top_artists_last_7_days()
            end note
        }
    }

    file "retrieve.py\n(Standalone script)" as retrieve

    package "⚛️ Frontend - frontend/" <<FRONTEND_COLOR>> {
        
        package "Configuration" {
            file "package.json\n(Dependencies)" as package_json
            file "vite.config.js\n(Vite config)" as vite_config
            file "eslint.config.js\n(Linter config)" as eslint_config
            file "index.html\n(HTML entry)" as index_html
        }
        
        package "src/" {
            
            file "main.jsx\n(React entry point)" as main
            file "App.jsx\n(Root component)" as app_jsx
            file "App.css\n(App styles)" as app_css
            file "index.css\n(Global styles)" as index_css
            note right of app_jsx
                • Manages auth state
                • Handles token
                • Routes between pages
                • Loads user data
            end note
            
            package "api/" {
                file "spotify.js\n(API client)" as spotify_api
                note right of spotify_api
                    Export functions:
                    • fetchUser()
                    • fetchRecentlyPlayed()
                    • fetchTopTracks()
                    • fetchTopArtists()
                end note
            }
            
            package "components/" {
                file "Header.jsx\n(User profile header)" as header
                file "Tabs.jsx\n(Navigation tabs)" as tabs
                file "PeriodPills.jsx\n(Time period selector)" as period_pills
                file "TrackList.jsx\n(Track display)" as track_list
                file "ArtistList.jsx\n(Artist display)" as artist_list
            }
            
            package "pages/" {
                file "RecentlyPlayed.jsx\n(Recent tracks page)" as recently_played
                file "TopTracks.jsx\n(Top tracks page)" as top_tracks
                file "TopArtists.jsx\n(Top artists page)" as top_artists
            }
            
            package "assets/" {
                file "hero.png" as hero
                file "react.svg" as react_svg
                file "vite.svg" as vite_svg
            }
        }
        
        package "public/" {
            file "favicon.svg" as favicon
            file "icons.svg" as icons_svg
        }
        
        package "node_modules/" <<CONFIG_COLOR>> {
            note
                Dependencies:
                • react
                • react-dom
                • axios
                • vite
                • eslint
                (auto-installed by npm)
            end note
        }
    }
}

app_jsx --|> main : rendered by
app_jsx --|> header : uses
app_jsx --|> tabs : uses
app_jsx --|> recently_played : conditional render
app_jsx --|> top_tracks : conditional render
app_jsx --|> top_artists : conditional render

recently_played --|> track_list : uses
top_tracks --|> period_pills : uses
top_tracks --|> track_list : uses
top_artists --|> period_pills : uses
top_artists --|> artist_list : uses

spotify_api --|> app_jsx : imported by
spotify_api --|> recently_played : called by
spotify_api --|> top_tracks : called by
spotify_api --|> top_artists : called by

app_routes --|> spotify_client : uses
app_routes --|> spotify_data : imports

@enduml
