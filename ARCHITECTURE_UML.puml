@startuml Spotify-Visualizer-Architecture

!define FOLDER_COLOR #E1F5FE
!define BACKEND_COLOR #C8E6C9
!define FRONTEND_COLOR #FFE0B2
!define COMPONENT_COLOR #F8BBD0

skinparam backgroundColor #FAFAFA
skinparam defaultFontColor #333333

package "Spotify-Visualizer" {
    
    package "Backend (Python/Flask)" <<BACKEND_COLOR>> {
        package "app/" {
            file "__init__.py" as app_init
            file "__main__.py" as app_main
            file "routes.py" as app_routes
            
            package "services/" {
                file "spotify_client.py" as spotify_client
                file "spotify_data.py" as spotify_data
            }
        }
        
        file "retrieve.py" as retrieve
        file "requirements.txt" as requirements
    }
    
    package "Frontend (React/Vite)" <<FRONTEND_COLOR>> {
        package "src/" {
            file "main.jsx" as main
            file "App.jsx" as app_jsx
            file "App.css" as app_css
            file "index.css" as index_css
            
            package "api/" {
                file "spotify.js" as spotify_api
            }
            
            package "components/" {
                file "Header.jsx" as header
                file "Tabs.jsx" as tabs
                file "PeriodPills.jsx" as period_pills
                file "TrackList.jsx" as track_list
                file "ArtistList.jsx" as artist_list
            }
            
            package "pages/" {
                file "RecentlyPlayed.jsx" as recently_played
                file "TopTracks.jsx" as top_tracks
                file "TopArtists.jsx" as top_artists
            }
        }
        
        file "index.html" as index_html
        file "vite.config.js" as vite_config
        file "package.json" as package_json
    }
    
    package "Configuration" {
        file ".env" as env_file
        file ".gitignore" as gitignore
        file "ARCHITECTURE.md" as arch_doc
        file "SETUP_AND_RUN.md" as setup_doc
    }
}

' Backend Flow
app_routes --> spotify_client : uses
app_routes --> spotify_data : imports functions
spotify_client --> retrieve : referenced by

' Frontend Flow
main --> app_jsx : renders
app_jsx --> spotify_api : imports
app_jsx --> header : renders
app_jsx --> tabs : renders
app_jsx --> recently_played : renders based on tab
app_jsx --> top_tracks : renders based on tab
app_jsx --> top_artists : renders based on tab

recently_played --> spotify_api : calls API
top_tracks --> spotify_api : calls API
top_artists --> spotify_api : calls API

header --> app_jsx : child component
tabs --> app_jsx : child component
period_pills --> top_tracks : used by
period_pills --> top_artists : used by
track_list --> recently_played : displays data
track_list --> top_tracks : displays data
artist_list --> top_artists : displays data

' Styling
app_css --> app_jsx : imported
index_css --> main : imported

' Configuration
index_html --> main : loads script

note right of app_routes
  **API Endpoints:**
  - /login
  - /callback
  - /user
  - /recent
  - /top/tracks/<period>
  - /top/artists/<period>
end note

note right of spotify_api
  **API Functions:**
  - fetchUser(token)
  - fetchRecentlyPlayed(token)
  - fetchTopTracks(token, period)
  - fetchTopArtists(token, period)
end note

@enduml
